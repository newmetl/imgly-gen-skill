{
  "name": "cesdk-social-skill",
  "version": "0.1.0",
  "description": "MCP Skill für KI-gestützte Social-Media-Bildgenerierung mit CE.SDK",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cesdk-social-skill": "dist/index.js"
  },
  "scripts": {
    "install:all": "npm install && npm --prefix editor-app install",
    "build": "tsc && npm --prefix editor-app run build",
    "build:server": "tsc",
    "build:editor": "npm --prefix editor-app run build",
    "dev:editor": "npm --prefix editor-app run dev",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "smoketest:bootstrap": "tsx scripts/smoketest-bootstrap.ts",
    "smoketest:render": "tsx scripts/smoketest-render.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cesdk/node": "^1.73.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
